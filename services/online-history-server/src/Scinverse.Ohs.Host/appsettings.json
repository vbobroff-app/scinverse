{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "ConnectionStrings": {
    "Timescale": "Host=localhost;Port=5432;Database=scinverse;Username=scinverse;Password=scinverse"
  },
  "Ohs": {
    "UseFakeConnector": true,
    "Instruments": [
      { "Seccode": "SBER", "Board": "TQBR" }
    ]
  },
  "Transaq": {
    "DllPath": "txmlconnector.dll",
    "Login": "",
    "Password": "",
    "Host": "",
    "Port": 0,
    "LogDir": "logs/transaq",
    "LogLevel": 2
  },
  "Batcher": {
    "BatchSize": 5000,
    "FlushInterval": "00:00:00.500",
    "Capacity": 100000
  }
}
