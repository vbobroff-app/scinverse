{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Scinverse.Ohs.Host.RecordingSupervisor": "Debug",
        "Scinverse.Ohs.Host.LivenessProbe": "Debug"
      }
    },
    "WriteTo": [
      { "Name": "Console", "Args": { "restrictedToMinimumLevel": "Information" } },
      {
        "Name": "File",
        "Args": {
          "path": "logs/ohs-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "restrictedToMinimumLevel": "Debug",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Timescale": "Host=localhost;Port=5432;Database=scinverse;Username=scinverse;Password=scinverse"
  },
  "Ohs": {
    "UseFakeConnector": true,
    "LivenessProbeSeconds": 15,
    "Instruments": [
      { "Ticker": "SBER", "Board": "TQBR" }
    ]
  },
  "Transaq": {
    // ВНИМАНИЕ: Login/Password/Host/DllPath здесь НЕ хранятся. Для локальной разработки
    // задавать в appsettings.Local.json (в .gitignore, см. appsettings.Local.example.json)
    // либо через user-secrets / переменные окружения (Transaq__Password=...).
    "DllPath": "native/txmlconnector64.dll",
    "Host": "",
    "Port": 0,
    "LogDir": "logs/transaq",
    "LogLevel": 2
  },
  "Batcher": {
    "BatchSize": 5000,
    "FlushInterval": "00:00:00.500",
    "Capacity": 100000
  }
}
